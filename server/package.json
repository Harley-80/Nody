{
    "name": "server",
    "version": "1.0.0",
    "description": "Serveur backend pour la plateforme e-commerce Nody",
    "main": "server.js",
    "type": "module",
    "scripts": {
        "test": "echo \"Error: no test specified\" && exit 1",
        "start": "node server.js",
        "dev": "nodemon server.js",
        "seed": "node seeders/seeder.js",
        "seed:categories": "node scripts/peuplerCategories.js",
        "seed:produits": "node --env-file=../.env ./seeders/seeder.js --import produits",
        "seed:utilisateurs": "node --env-file=../.env ./seeders/seeder.js --import utilisateurs",
        "seed:commandes": "node --env-file=../.env ./seeders/seeder.js --import commandes",
        "seed:paiements": "node --env-file=../.env ./seeders/seeder.js --import paiements",
        "seed:destroy": "node --env-file=../.env ./seeders/seeder.js --destroy",
        "seed:admin": "node seeders/scripts/seedAdmin.js",
        "seed:admin-simple": "node seeders/scripts/seedAdminSimple.js",
        "seed:moderateurs": "node seeders/scripts/seedModerateurs.js",
        "seed:vendeurs": "node seeders/scripts/seedVendeurs.js",
        "seed:all-roles": "node seeders/scripts/seedTousRoles.js",
        "seed:complete": "npm run seed:all-roles && npm run seed:produits",
        "seed:products": "node scripts/peuplerProduits.js",
        "seed:all": "node scripts/peuplerBaseDeDonnees.js"
    },
    "keywords": [
        "ecommerce",
        "mode",
        "mern",
        "nodejs"
    ],
    "author": "Harley Fedy NDOUYI",
    "license": "MIT",
    "dependencies": {
        "@google-cloud/vision": "^5.3.4",
        "axios": "^1.13.2",
        "bcryptjs": "^3.0.2",
        "compression": "^1.8.1",
        "connect-redis": "^9.0.0",
        "cors": "^2.8.5",
        "date-fns": "^4.1.0",
        "dotenv": "^17.2.2",
        "express": "^5.1.0",
        "express-async-handler": "^1.2.0",
        "express-rate-limit": "^8.1.0",
        "express-session": "^1.18.2",
        "express-validator": "^7.2.1",
        "helmet": "^8.1.0",
        "ioredis": "^5.8.2",
        "jsonwebtoken": "^9.0.2",
        "mongo-sanitize": "^1.1.0",
        "mongoose": "^8.19.1",
        "mongoose-paginate-v2": "^1.9.1",
        "morgan": "^1.10.1",
        "multer": "^2.0.2",
        "node-cron": "^4.2.1",
        "nodemailer": "^8.0.7",
        "pdfkit": "^0.17.2",
        "redis": "^5.9.0",
        "sharp": "^0.34.5",
        "slugify": "^1.6.6",
        "socket.io": "^4.2.0",
        "stripe": "^18.5.0",
        "winston": "^3.17.0"
    },
    "devDependencies": {
        "@faker-js/faker": "^10.1.0",
        "chalk": "^5.3.0",
        "nodemon": "^3.1.10",
        "sass": "^1.92.1"
    }
}
